# --- Lumina Copilot Backend Configuration ---

# Security
LUMINA_API_KEY=your-secret-key-here
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# LLM Providers (Minimum one required)
GEMINI_API_KEY=your-gemini-key
OPENAI_API_KEY=your-openai-key
# Ollama falls back to local (no key needed)

# Research Tools
INDIAN_KANOON_API_TOKEN=your-indian-kanoon-token

# Environment
TOKENIZERS_PARALLELISM=false
OMP_NUM_THREADS=1

# --- Frontend Configuration ---
VITE_LUMINA_API_KEY=your-secret-key-here (must match backend)
VITE_API_BASE_URL=/api
