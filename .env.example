# ==========================================
# LUMINA COPILOT ENVIRONMENT CONFIGURATION
# ==========================================

# --- 1. LLM External Providers ---
# Primary LLM (Gemini 1.5 Pro/Flash)
GEMINI_API_KEY="your_gemini_api_key_here"
# Fallback LLM (OpenAI GPT-4o-mini)
OPENAI_API_KEY="your_openai_api_key_here"

# --- 2. API Security & Network ---
# The primary API key for clients consuming the Lumina backend endpoints
LUMINA_API_KEY="secret-lumina-key-2026"
# Cross-origin allowed domains (comma-separated, typically frontend URLs)
ALLOWED_ORIGINS="http://localhost:5173,http://localhost:3000"
# Root URL of this backend (used locally and by frontend proxies occasionally)
BACKEND_URL="http://localhost:8000"

# --- 3. External API Integrations ---
# Indian Kanoon token for fetching live case laws (Optional)
INDIAN_KANOON_API_TOKEN="your_token_here"
